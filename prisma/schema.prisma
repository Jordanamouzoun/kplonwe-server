generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String          @id @default(uuid())
  email                     String          @unique
  password                  String
  role                      String
  firstName                 String?
  lastName                  String?
  phone                     String?
  avatar                    String?
  isVerified                Boolean         @default(false)
  isActive                  Boolean         @default(true)
  termsAccepted             Boolean         @default(false)
  termsAcceptedAt           DateTime?
  termsVersion              String?
  lastLogin                 DateTime?
  accessibilitySettings     String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  resetCode                 String?
  resetCodeExpiresAt        DateTime?
  forumComments             ForumComment[]
  forumPosts                ForumPost[]
  notifications             Notification[]
  parentProfile             ParentProfile?
  reviews                   Review[]
  schoolProfile             SchoolProfile?
  sessions                  Session[]
  studentProfile            StudentProfile?
  teacherProfile            TeacherProfile?
  wallet                    Wallet?

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model TeacherProfile {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  bio                   String?
  subjects              String
  experience            Int?
  education             String?
  certifications        String?
  documents             String?
  pricePerMonth         Float?
  levels                String?
  validationStatus      String                 @default("PENDING")
  validationComment     String?
  validatedBy           String?
  validatedAt           DateTime?
  isPremium             Boolean                @default(false)
  premiumUntil          DateTime?
  rating                Float                  @default(1.0)
  reviewCount           Int                    @default(0)
  totalStudents         Int                    @default(0)
  totalEarnings         Float                  @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  points                Int                    @default(0)
  pricePerHour          Float?
  specialty             String?
  city                  String?
  isAvailable           Boolean                @default(true)
  evaluationAssignments EvaluationAssignment[]
  qcmResults            QCMResult[]
  quizzes               Quiz[]
  reviews               Review[]
  linkedStudents        StudentTeacherLink[]
  subscriptions         Subscription[]
  teacherDocuments      TeacherDocument[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([validationStatus])
  @@index([userId])
}

model ParentProfile {
  id        String              @id @default(uuid())
  userId    String              @unique
  children  String?
  address   String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  students  StudentParentLink[]

  @@index([userId])
}

model StudentProfile {
  id             String               @id @default(uuid())
  userId         String               @unique
  grade          String?
  schoolName     String?
  subjects       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  progress       Progress[]
  quizResults    QuizResult[]
  parents        StudentParentLink[]
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedTeachers StudentTeacherLink[]

  @@index([userId])
}

model SchoolProfile {
  id                 String           @id @default(uuid())
  userId             String           @unique
  schoolName         String
  registrationNumber String?          @unique
  address            String?
  phone              String?
  website            String?
  description        String?
  logo               String?
  hasSubscription    Boolean          @default(false)
  subscriptionUntil  DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  evaluationQuizzes  EvaluationQuiz[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions      Subscription[]

  @@index([userId])
}

model StudentParentLink {
  id           String         @id @default(uuid())
  studentId    String
  parentId     String
  relationship String?
  createdAt    DateTime       @default(now())
  parent       ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
}

model QCM {
  id          String        @id @default(uuid())
  title       String
  description String?
  subject     String
  minScore    Int
  duration    Int?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   QCMQuestion[]
  results     QCMResult[]

  @@index([subject])
  @@index([isActive])
}

model QCMQuestion {
  id            String   @id @default(uuid())
  qcmId         String
  question      String
  options       String
  correctAnswer Int
  points        Int      @default(1)
  order         Int      @default(0)
  explanation   String?
  createdAt     DateTime @default(now())
  qcm           QCM      @relation(fields: [qcmId], references: [id], onDelete: Cascade)

  @@index([qcmId])
}

model QCMResult {
  id          String         @id @default(uuid())
  qcmId       String
  teacherId   String
  score       Float
  passed      Boolean
  answers     String
  startedAt   DateTime
  completedAt DateTime       @default(now())
  qcm         QCM            @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([qcmId])
}

model Quiz {
  id          String           @id @default(uuid())
  title       String
  description String?
  subject     String
  createdBy   String
  status      String           @default("DRAFT")
  duration    Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  coverImage  String?
  teacher     TeacherProfile   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  assignments QuizAssignment[]
  questions   QuizQuestion[]
  results     QuizResult[]

  @@index([createdBy])
  @@index([status])
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  question      String
  type          String
  options       String?
  correctAnswer String
  points        Int      @default(1)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  coverImage    String?
  duration      Int?
  pointsType    String   @default("STANDARD")
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAssignment {
  id         String    @id @default(uuid())
  quizId     String
  studentId  String
  dueDate    DateTime?
  assignedAt DateTime  @default(now())
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId])
  @@index([studentId])
}

model QuizResult {
  id          String         @id @default(uuid())
  quizId      String
  studentId   String
  score       Float
  answers     String
  timeSpent   Int
  startedAt   DateTime
  completedAt DateTime       @default(now())
  quiz        Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([quizId])
}

model Progress {
  id           String         @id @default(uuid())
  studentId    String
  subject      String
  level        Int            @default(0)
  xp           Int            @default(0)
  timeSpent    Int            @default(0)
  lastActivity DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject])
  @@index([studentId])
}

model Wallet {
  id               String        @id @default(uuid())
  userId           String        @unique
  balance          Float         @default(0)
  currency         String        @default("XOF")
  isLocked         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  transactionsFrom Transaction[] @relation("TransactionFrom")
  transactionsTo   Transaction[] @relation("TransactionTo")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id               String   @id @default(uuid())
  reference        String   @unique
  type             String
  amount           Float
  currency         String   @default("XOF")
  status           String   @default("PENDING")
  fromWalletId     String?
  toWalletId       String?
  paymentMethod    String?
  description      String?
  metadata         String?
  providerRef      String?
  providerResponse String?
  isLocked         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  fromWallet       Wallet?  @relation("TransactionFrom", fields: [fromWalletId], references: [id])
  toWallet         Wallet?  @relation("TransactionTo", fields: [toWalletId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([type])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
}

model Subscription {
  id            String          @id @default(uuid())
  type          String
  userId        String
  teacherId     String?
  schoolId      String?
  amount        Float
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean         @default(true)
  autoRenew     Boolean         @default(false)
  transactionId String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  school        SchoolProfile?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([teacherId])
  @@index([schoolId])
  @@index([endDate])
  @@index([isActive])
}

model ForumPost {
  id        String         @id @default(uuid())
  authorId  String
  title     String
  content   String
  subject   String?
  views     Int            @default(0)
  isPinned  Boolean        @default(false)
  isLocked  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  likes     Int            @default(0)
  comments  ForumComment[]
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([subject])
  @@index([createdAt])
}

model ForumComment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  likes     Int       @default(0)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model Review {
  id        String         @id @default(uuid())
  teacherId String
  authorId  String
  rating    Int
  comment   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([authorId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   String?
  stack     String?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model Conversation {
  id               String    @id @default(uuid())
  participant1Id   String
  participant1Role String
  participant2Id   String
  participant2Role String
  lastMessageAt    DateTime  @default(now())
  isBlocked        Boolean   @default(false)
  blockedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  messages         Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  senderRole     String
  receiverId     String
  receiverRole   String
  content        String
  readAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model NotificationModel {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model TeacherDocument {
  id           String         @id @default(uuid())
  teacherId    String
  type         String
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  filePath     String
  status       String         @default("PENDING")
  uploadedAt   DateTime       @default(now())
  verifiedAt   DateTime?
  verifiedBy   String?
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([status])
}

model EvaluationQuiz {
  id           String                 @id @default(uuid())
  schoolId     String
  title        String
  description  String?
  subject      String?
  passingScore Int                    @default(70)
  timeLimit    Int?
  status       String                 @default("DRAFT")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  assignments  EvaluationAssignment[]
  questions    EvaluationQuestion[]
  school       SchoolProfile          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([status])
}

model EvaluationQuestion {
  id            String         @id @default(uuid())
  quizId        String
  question      String
  type          String
  options       String?
  correctAnswer String
  points        Int            @default(1)
  order         Int            @default(0)
  createdAt     DateTime       @default(now())
  quiz          EvaluationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model EvaluationAssignment {
  id          String         @id @default(uuid())
  quizId      String
  teacherId   String
  status      String         @default("PENDING")
  score       Float?
  passed      Boolean?
  answers     String?
  startedAt   DateTime?
  completedAt DateTime?
  assignedAt  DateTime       @default(now())
  quiz        EvaluationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([quizId, teacherId])
  @@index([teacherId])
  @@index([quizId])
}

model ParentTeacherLink {
  id        String   @id @default(uuid())
  parentId  String
  teacherId String
  createdAt DateTime @default(now())

  @@unique([parentId, teacherId])
  @@index([parentId])
  @@index([teacherId])
  @@index([createdAt])
}

model StudentTeacherLink {
  id        String         @id @default(uuid())
  studentId String
  teacherId String
  status    String         @default("ACTIVE")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([studentId, teacherId])
  @@index([studentId])
  @@index([teacherId])
}
