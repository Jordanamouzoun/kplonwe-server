generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite ne supporte pas les enums natifs
// On utilise des String avec valeurs par défaut

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // ADMIN, TEACHER, PARENT, STUDENT, SCHOOL
  firstName String?
  lastName  String?
  phone     String?
  avatar    String?
  isVerified Boolean @default(false)
  isActive  Boolean  @default(true)
  termsAccepted Boolean @default(false)
  termsAcceptedAt DateTime?
  termsVersion String?
  lastLogin DateTime?
  
  accessibilitySettings String? // JSON
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile  TeacherProfile?
  parentProfile   ParentProfile?
  studentProfile  StudentProfile?
  schoolProfile   SchoolProfile?
  wallet          Wallet?
  forumPosts      ForumPost[]
  forumComments   ForumComment[]
  notifications   Notification[]
  sessions        Session[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model TeacherProfile {
  id                String           @id @default(uuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio               String?
  subjects          String           // JSON array
  experience        Int?
  education         String?
  certifications    String?          // JSON array
  documents         String?          // JSON array
  
  // Prix et niveaux
  pricePerMonth     Float?           // Prix mensuel en FCFA
  levels            String?          // JSON array - Niveaux enseignés (CE1, CE2, etc.)
  
  validationStatus  String           @default("PENDING") // PENDING, VERIFIED, REJECTED
  validationComment String?
  validatedBy       String?
  validatedAt       DateTime?
  
  isPremium         Boolean          @default(false)
  premiumUntil      DateTime?
  
  rating            Float            @default(0)
  reviewCount       Int              @default(0)
  totalStudents     Int              @default(0)
  totalEarnings     Float            @default(0)
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  qcmResults        QCMResult[]
  quizzes           Quiz[]
  reviews           Review[]
  subscriptions     Subscription[]
  teacherDocuments  TeacherDocument[]
  evaluationAssignments EvaluationAssignment[]
  
  @@index([validationStatus])
  @@index([userId])
}

model ParentProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  children  String?  // JSON array
  address   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  StudentParentLink[]
  
  @@index([userId])
}

model StudentProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  grade     String?
  schoolName String?
  subjects  String?  // JSON array
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parents   StudentParentLink[]
  quizResults QuizResult[]
  progress  Progress[]
  
  @@index([userId])
}

model SchoolProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  schoolName    String
  registrationNumber String? @unique
  address       String?
  phone         String?
  website       String?
  description   String?
  logo          String?
  
  hasSubscription Boolean  @default(false)
  subscriptionUntil DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  evaluationQuizzes EvaluationQuiz[]
  
  @@index([userId])
}

model StudentParentLink {
  id        String   @id @default(uuid())
  studentId String
  parentId  String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent    ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  relationship String?
  createdAt DateTime @default(now())

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
}

model QCM {
  id          String   @id @default(uuid())
  title       String
  description String?
  subject     String
  minScore    Int
  duration    Int?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   QCMQuestion[]
  results     QCMResult[]
  
  @@index([subject])
  @@index([isActive])
}

model QCMQuestion {
  id        String   @id @default(uuid())
  qcmId     String
  qcm       QCM      @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  
  question  String
  options   String   // JSON array
  correctAnswer Int
  points    Int      @default(1)
  order     Int      @default(0)
  explanation String?
  
  createdAt DateTime @default(now())

  @@index([qcmId])
}

model QCMResult {
  id        String   @id @default(uuid())
  qcmId     String
  qcm       QCM      @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  score     Float
  passed    Boolean
  answers   String   // JSON
  
  startedAt DateTime
  completedAt DateTime @default(now())

  @@index([teacherId])
  @@index([qcmId])
}

model Quiz {
  id          String     @id @default(uuid())
  title       String
  description String?
  subject     String
  createdBy   String
  teacher     TeacherProfile @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  
  status      String     @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  duration    Int?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions   QuizQuestion[]
  assignments QuizAssignment[]
  results     QuizResult[]
  
  @@index([createdBy])
  @@index([status])
}

model QuizQuestion {
  id        String   @id @default(uuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  question  String
  type      String
  options   String?
  correctAnswer String
  points    Int      @default(1)
  order     Int      @default(0)
  
  createdAt DateTime @default(now())

  @@index([quizId])
}

model QuizAssignment {
  id        String   @id @default(uuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId String
  
  dueDate   DateTime?
  assignedAt DateTime @default(now())

  @@unique([quizId, studentId])
  @@index([studentId])
}

model QuizResult {
  id        String   @id @default(uuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  score     Float
  answers   String
  timeSpent Int
  
  startedAt DateTime
  completedAt DateTime @default(now())

  @@index([studentId])
  @@index([quizId])
}

model Progress {
  id        String   @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  subject   String
  level     Int      @default(0)
  xp        Int      @default(0)
  timeSpent Int      @default(0)
  
  lastActivity DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subject])
  @@index([studentId])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  balance   Float    @default(0)
  currency  String   @default("XOF")
  isLocked  Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionsFrom Transaction[] @relation("TransactionFrom")
  transactionsTo   Transaction[] @relation("TransactionTo")
  
  @@index([userId])
}

model Transaction {
  id            String            @id @default(uuid())
  reference     String            @unique
  
  type          String            // RECHARGE, PAYMENT, COMMISSION, SUBSCRIPTION, REFUND, WITHDRAWAL
  amount        Float
  currency      String            @default("XOF")
  status        String            @default("PENDING") // PENDING, COMPLETED, FAILED, CANCELLED, REFUNDED
  
  fromWalletId  String?
  fromWallet    Wallet?           @relation("TransactionFrom", fields: [fromWalletId], references: [id])
  toWalletId    String?
  toWallet      Wallet?           @relation("TransactionTo", fields: [toWalletId], references: [id])
  
  paymentMethod String?           // MOMO, MOOV, CARD_STRIPE, CARD_PAYSTACK, WALLET
  description   String?
  metadata      String?           // JSON
  
  providerRef   String?
  providerResponse String?        // JSON
  
  isLocked      Boolean           @default(false)
  
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([type])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
}

model Subscription {
  id            String           @id @default(uuid())
  
  type          String           // TEACHER_PREMIUM, SCHOOL_QUIZ
  userId        String
  
  teacherId     String?
  teacher       TeacherProfile?  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  schoolId      String?
  school        SchoolProfile?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  amount        Float
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean          @default(true)
  autoRenew     Boolean          @default(false)
  
  transactionId String?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([teacherId])
  @@index([schoolId])
  @@index([endDate])
  @@index([isActive])
}

model ForumPost {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  title     String
  content   String
  subject   String?
  
  views     Int      @default(0)
  likes     Int      @default(0)
  isPinned  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  ForumComment[]
  
  @@index([authorId])
  @@index([subject])
  @@index([createdAt])
}

model ForumComment {
  id        String    @id @default(uuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  content   String
  likes     Int       @default(0)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId])
  @@index([authorId])
}

model Review {
  id        String   @id @default(uuid())
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  authorId  String
  
  rating    Int
  comment   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([authorId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String
  title     String
  message   String
  data      String?
  link      String?
  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   String?
  stack     String?
  createdAt DateTime @default(now())
  
  @@index([level])
  @@index([createdAt])
}

model Conversation {
  id               String   @id @default(uuid())
  participant1Id   String
  participant1Role String   // PARENT, TEACHER, STUDENT, SCHOOL
  participant2Id   String
  participant2Role String
  
  // Métadonnées
  lastMessageAt    DateTime @default(now())
  isBlocked        Boolean  @default(false)
  blockedBy        String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages         Message[]
  
  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId       String
  senderRole     String   // PARENT, TEACHER, STUDENT, SCHOOL
  receiverId     String
  receiverRole   String
  
  content        String
  
  readAt         DateTime?
  deletedAt      DateTime?
  
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model NotificationModel {
  id        String   @id @default(uuid())
  userId    String
  
  type      String   // NEW_MESSAGE, TEACHER_LINKED, PAYMENT_RECEIVED
  title     String
  message   String
  data      String?  // JSON
  
  isRead    Boolean  @default(false)
  readAt    DateTime?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model TeacherDocument {
  id          String   @id @default(uuid())
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  type        String   // DIPLOMA, CERTIFICATE, ID_CARD, OTHER
  fileName    String
  originalName String
  fileSize    Int
  mimeType    String
  filePath    String
  
  status      String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  
  uploadedAt  DateTime @default(now())
  verifiedAt  DateTime?
  verifiedBy  String?
  
  @@index([teacherId])
  @@index([status])
}

model EvaluationQuiz {
  id            String   @id @default(uuid())
  schoolId      String
  school        SchoolProfile @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  subject       String?
  
  passingScore  Int      @default(70) // Pourcentage minimum pour passer
  timeLimit     Int?     // Minutes, null = pas de limite
  
  status        String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions     EvaluationQuestion[]
  assignments   EvaluationAssignment[]
  
  @@index([schoolId])
  @@index([status])
}

model EvaluationQuestion {
  id        String   @id @default(uuid())
  quizId    String
  quiz      EvaluationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  question  String
  type      String   // MCQ, TRUE_FALSE, SHORT_ANSWER
  options   String?  // JSON array for MCQ
  correctAnswer String
  points    Int      @default(1)
  order     Int      @default(0)
  
  createdAt DateTime @default(now())

  @@index([quizId])
}

model EvaluationAssignment {
  id          String   @id @default(uuid())
  quizId      String
  quiz        EvaluationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  status      String   @default("PENDING") // PENDING, STARTED, COMPLETED
  score       Float?
  passed      Boolean?
  answers     String?  // JSON
  
  startedAt   DateTime?
  completedAt DateTime?
  assignedAt  DateTime @default(now())

  @@unique([quizId, teacherId])
  @@index([teacherId])
  @@index([quizId])
}
