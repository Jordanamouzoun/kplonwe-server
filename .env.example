# ========================================
# KPLONWE BACKEND - VARIABLES D'ENVIRONNEMENT PRODUCTION
# ========================================

# ── BASE DE DONNÉES (PostgreSQL sur Render) ──
# Render fournit automatiquement cette URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@host.render.com:5432/kplonwe_db"

# ── JWT SECRETS ──
# IMPORTANT: Générer des secrets forts et uniques !
# Utiliser: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERATE_A_STRONG_SECRET_HERE_64_CHARS_MIN"
JWT_REFRESH_SECRET="GENERATE_ANOTHER_STRONG_SECRET_HERE_64_CHARS_MIN"

# ── CORS ──
# URL de votre frontend déployé sur Vercel
FRONTEND_URL="https://votre-app.vercel.app"
CORS_ORIGIN="https://votre-app.vercel.app"

# ── SERVER ──
PORT=5000
NODE_ENV="production"

# ── STRIPE (Paiements) ──
# Clés de production Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── UPLOAD FILES ──
# Limite de taille des fichiers (en bytes)
MAX_FILE_SIZE=10485760
# Dossier pour les uploads (Render Disks)
UPLOAD_DIR="/var/data/uploads"

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ── LOGS ──
LOG_LEVEL="info"
LOG_DIR="/var/data/logs"

# ── EMAIL (Optionnel - pour notifications) ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-app"
EMAIL_FROM="KPLONWE <noreply@kplonwe.com>"

# ── ADMIN PAR DÉFAUT ──
DEFAULT_ADMIN_EMAIL="admin@kplonwe.com"
DEFAULT_ADMIN_PASSWORD="ChangeThisPassword123!"
DEFAULT_ADMIN_FIRSTNAME="Admin"
DEFAULT_ADMIN_LASTNAME="KPLONWE"
