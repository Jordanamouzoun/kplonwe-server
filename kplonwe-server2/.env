# Base de données SQLite locale
DATABASE_URL="file:./prisma/kplonwe.db"

# JWT Secrets (changez en production)
JWT_SECRET="kplonwe-super-secret-key-change-me-in-production-2026"
JWT_REFRESH_SECRET="kplonwe-refresh-secret-key-change-me-in-production-2026"

# URLs
FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# Upload config
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=".jpg,.jpeg,.png,.pdf,.doc,.docx"

# Stripe (optionnel - laissez vide si non utilisé)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (optionnel - configurez si vous voulez les emails)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# Cloudinary (optionnel - pour le stockage d'images)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
